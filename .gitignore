# OS
.DS_Store

# Internal working directory — drafts, audits, transcripts, intermediate scope docs.
# Final scope is published under docs/ instead.
Local_Dev/

# Internal planning / branch tracking — between local working repo only.
BRANCH_LOG.md

# Demo scripts — internal preparation notes / talk tracks for stakeholder
# walkthroughs. Not part of the shipped accelerator.
demos/

# Spec Kit planning workspace — internal structured planning, not for stakeholders.
.specify/
specs/

# Editor/agent integration — may contain credentials per upstream guidance.
.cursor/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Bundle outputs (per-engagement; never committed)
bundle/
bundle_*/
# ...but the `dla.bundle` source package must always be tracked (the rule above
# otherwise matches it by directory name).
!apps/dla/src/dla/bundle/
!apps/dla/src/dla/bundle/**

# Node / web UI build artifacts
node_modules/
dist/
build/
.next/
.cache/

# Logs and temp files
*.log
*.tmp
.cache

# macOS file-restore duplicates (e.g. "config 2.py") — never commit these
* 2.*
* 2
